# Same Mongo cluster/URI as Nicha by AssetHub
MONGODB_URI=

# Asset Hub's own DB for reviews/articles/admin data
# Optional; default: asset-ace
# MONGODB_DB_NAME=asset-hub

# Asset Ace DB for reading shared property listings via the same Mongo connection pool
# Optional; default: asset-ace
# ASSET_ACE_MONGODB_DB_NAME=asset-ace

# Firebase (Analytics) – from Firebase Console > Project settings > Your apps > Web app
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# AWS S3 (for property images – same bucket as Nicha by AssetHub)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=

# DDproperty RealtimeAPI (New to Market section)
RAPIDAPI_KEY=

# NextAuth (Sign-in: Google only; LINE uses LIFF)
# NEXTAUTH_URL must match the URL you open (app runs on port 3001)
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# LINE: LIFF (same as Nicha by AssetHub) – get LIFF ID from LINE Developers > LINE Login > LIFF
# LINE บังคับ Endpoint URL ต้องเป็น HTTPS เท่านั้น
# Development: ใช้ tunnel เช่น ngrok (ngrok http 3001) แล้วตั้ง Endpoint = https://xxx.ngrok-free.app/sign-in/line
# Production: ตั้ง Endpoint URL = https://your-domain.com/sign-in/line
NEXT_PUBLIC_LIFF_ID=
# LINE Official Account ID (เช่น @yourid) สำหรับปุ่ม "เพิ่มเพื่อนใน LINE" บนหน้า /post
NEXT_PUBLIC_LINE_OFFICIAL_ID=
# Optional: redirect after sign-in (default: https://www.assethub.in.th/admin/dashboard)
# NEXTAUTH_REDIRECT_AFTER_SIGNIN=https://www.assethub.in.th/admin/dashboard
# Local only: show "Dev: Login as test user" on sign-in to bypass LINE (NODE_ENV=development)
# NEXT_PUBLIC_ALLOW_DEV_LOGIN=true

# Admin: comma-separated user IDs that can access /admin (same id as in session: Google OAuth id or LINE userId)
# In development, if unset, every logged-in user is treated as admin (for local test user).
# ADMIN_USER_IDS=id1,id2

# Gemini API – for "ดึงข้อมูลจาก AI" button on Project Review (get key from https://aistudio.google.com/app/apikey)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash   # optional; default is gemini-2.0-flash
